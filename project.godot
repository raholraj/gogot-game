; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are pretty specific to its
; format and may change in future versions.

config_version=5

[application]

title="GOGOT GAME"
run=res://scenes/main.tscn
config/features=PackedStringArray("4.1", "forward_plus")
config/icon="res://assets/icon.svg"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/handheld/orientation="portrait"

[input]

move_left={"deadzone": 0.5, "events": [Object(InputEventKey,"keycode":65), Object(InputEventKey,"keycode":4194319)]}
move_right={"deadzone": 0.5, "events": [Object(InputEventKey,"keycode":68), Object(InputEventKey,"keycode":4194321)]}
switch_mode={"deadzone": 0.5, "events": [Object(InputEventKey,"keycode":4194305)]}
menu={"deadzone": 0.5, "events": [Object(InputEventKey,"keycode":4194305)]}

[physics]

2d/default_gravity=0.0
